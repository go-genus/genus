{
  "Genus Model": {
    "prefix": "genusmodel",
    "body": [
      "type ${1:ModelName} struct {",
      "\tcore.Model",
      "\t${2:Name} ${3:string} `db:\"${4:name}\"`",
      "\t$0",
      "}",
      "",
      "func (${5:m} *${1:ModelName}) TableName() string {",
      "\treturn \"${6:table_name}\"",
      "}"
    ],
    "description": "Create a Genus ORM model"
  },
  "Genus Fields": {
    "prefix": "genusfields",
    "body": [
      "var ${1:Model}Fields = struct {",
      "\t${2:Name} query.StringField",
      "\t$0",
      "}{",
      "\t${2:Name}: query.NewStringField(\"${3:name}\"),",
      "}"
    ],
    "description": "Create type-safe fields for a model"
  },
  "Genus Query Find": {
    "prefix": "genusfind",
    "body": [
      "${1:results}, err := genus.Table[${2:Model}](db).",
      "\tWhere(${2:Model}Fields.${3:Field}.${4:Eq}(${5:value})).",
      "\tFind(ctx)",
      "if err != nil {",
      "\treturn ${6:nil, }err",
      "}",
      "$0"
    ],
    "description": "Genus query with Find"
  },
  "Genus Query First": {
    "prefix": "genusfirst",
    "body": [
      "${1:result}, err := genus.Table[${2:Model}](db).",
      "\tWhere(${2:Model}Fields.${3:Field}.${4:Eq}(${5:value})).",
      "\tFirst(ctx)",
      "if err != nil {",
      "\treturn ${6:nil, }err",
      "}",
      "$0"
    ],
    "description": "Genus query with First"
  },
  "Genus Insert": {
    "prefix": "genusinsert",
    "body": [
      "${1:model} := &${2:Model}{",
      "\t${3:Field}: ${4:value},",
      "}",
      "if err := db.DB().Create(ctx, ${1:model}); err != nil {",
      "\treturn err",
      "}",
      "$0"
    ],
    "description": "Genus insert"
  },
  "Genus Update": {
    "prefix": "genusupdate",
    "body": [
      "${1:model}.${2:Field} = ${3:newValue}",
      "if err := db.DB().Update(ctx, ${1:model}); err != nil {",
      "\treturn err",
      "}",
      "$0"
    ],
    "description": "Genus update"
  },
  "Genus Delete": {
    "prefix": "genusdelete",
    "body": [
      "if err := db.DB().Delete(ctx, ${1:model}); err != nil {",
      "\treturn err",
      "}",
      "$0"
    ],
    "description": "Genus delete"
  },
  "Genus Transaction": {
    "prefix": "genustx",
    "body": [
      "err := db.DB().Transaction(ctx, func(tx *core.DB) error {",
      "\t$0",
      "\treturn nil",
      "})",
      "if err != nil {",
      "\treturn err",
      "}"
    ],
    "description": "Genus transaction"
  },
  "Genus Migration": {
    "prefix": "genusmigration",
    "body": [
      "package migrations",
      "",
      "import (",
      "\t\"context\"",
      "",
      "\t\"github.com/GabrielOnRails/genus/migrate\"",
      ")",
      "",
      "func init() {",
      "\tmigrate.Register(&migrate.Migration{",
      "\t\tVersion:     ${1:1},",
      "\t\tDescription: \"${2:description}\",",
      "\t\tUp: func(ctx context.Context, db migrate.Executor) error {",
      "\t\t\t_, err := db.ExecContext(ctx, `",
      "\t\t\t\t${3:CREATE TABLE ${4:table_name} (",
      "\t\t\t\t\tid SERIAL PRIMARY KEY,",
      "\t\t\t\t\tcreated_at TIMESTAMP DEFAULT NOW(),",
      "\t\t\t\t\tupdated_at TIMESTAMP DEFAULT NOW()",
      "\t\t\t\t)}",
      "\t\t\t`)",
      "\t\t\treturn err",
      "\t\t},",
      "\t\tDown: func(ctx context.Context, db migrate.Executor) error {",
      "\t\t\t_, err := db.ExecContext(ctx, `DROP TABLE IF EXISTS ${4:table_name}`)",
      "\t\t\treturn err",
      "\t\t},",
      "\t})",
      "}"
    ],
    "description": "Create a Genus migration"
  },
  "Genus Preload": {
    "prefix": "genuspreload",
    "body": [
      "${1:results}, err := genus.Table[${2:Model}](db).",
      "\tPreload(\"${3:RelationName}\").",
      "\tFind(ctx)",
      "if err != nil {",
      "\treturn ${4:nil, }err",
      "}",
      "$0"
    ],
    "description": "Genus query with Preload"
  },
  "Genus Join": {
    "prefix": "genusjoin",
    "body": [
      "${1:results}, err := genus.Table[${2:Model}](db).",
      "\tJoin(\"${3:related_table}\", \"${3:related_table}.${4:foreign_key} = ${5:table}.id\").",
      "\tFind(ctx)",
      "if err != nil {",
      "\treturn ${6:nil, }err",
      "}",
      "$0"
    ],
    "description": "Genus query with Join"
  },
  "Genus Aggregate": {
    "prefix": "genusaggregate",
    "body": [
      "${1:result}, err := genus.Table[${2:Model}](db).",
      "\tAggregate().",
      "\t${3:CountAll}().",
      "\tOne(ctx)",
      "if err != nil {",
      "\treturn ${4:0, }err",
      "}",
      "$0"
    ],
    "description": "Genus aggregation query"
  },
  "Genus Batch Insert": {
    "prefix": "genusbatch",
    "body": [
      "${1:models} := []*${2:Model}{",
      "\t{${3:Field}: ${4:value1}},",
      "\t{${3:Field}: ${5:value2}},",
      "}",
      "if err := db.DB().BatchInsert(ctx, ${1:models}); err != nil {",
      "\treturn err",
      "}",
      "$0"
    ],
    "description": "Genus batch insert"
  },
