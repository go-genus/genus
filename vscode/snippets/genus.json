  "Genus Command Handler": {
    "prefix": "genuscommand",
    "body": [
      "type ${1:CommandName}Command struct {",
      "\tcqrs.BaseCommand",
      "\t${2:Field} ${3:Type}",
      "}",
      "",
      "func New${1:CommandName}Command(${4:params}) *${1:CommandName}Command {",
      "\treturn &${1:CommandName}Command{",
      "\t\tBaseCommand: cqrs.NewBaseCommand(\"${1:CommandName}\"),",
      "\t\t${2:Field}: ${5:value},",
      "\t}",
      "}",
      "",
      "type ${1:CommandName}Handler struct {",
      "\t// dependencies",
      "}",
      "",
      "func (h *${1:CommandName}Handler) Handle(ctx context.Context, cmd *${1:CommandName}Command) error {",
      "\t$0",
      "\treturn nil",
      "}"
    ],
    "description": "Genus CQRS Command and Handler"
  },
  "Genus Query Handler": {
    "prefix": "genusquery",
    "body": [
      "type ${1:QueryName}Query struct {",
      "\tcqrs.BaseQuery",
      "\t${2:Field} ${3:Type}",
      "}",
      "",
      "type ${1:QueryName}Result struct {",
      "\t${4:ResultField} ${5:ResultType}",
      "}",
      "",
      "type ${1:QueryName}Handler struct {",
      "\t// dependencies",
      "}",
      "",
      "func (h *${1:QueryName}Handler) Handle(ctx context.Context, q *${1:QueryName}Query) (*${1:QueryName}Result, error) {",
      "\t$0",
      "\treturn &${1:QueryName}Result{}, nil",
      "}"
    ],
    "description": "Genus CQRS Query and Handler"
  },
  "Genus Event": {
    "prefix": "genusevent",
    "body": [
      "type ${1:EventName}Event struct {",
      "\tAggregateID   string    `json:\"aggregate_id\"`",
      "\tAggregateType string    `json:\"aggregate_type\"`",
      "\tVersion       int64     `json:\"version\"`",
      "\tTimestamp     time.Time `json:\"timestamp\"`",
      "\t${2:Field}    ${3:Type} `json:\"${4:field}\"`",
      "}",
      "",
      "func (e *${1:EventName}Event) EventType() string {",
      "\treturn \"${1:EventName}\"",
      "}"
    ],
    "description": "Genus Event Sourcing Event"
  }
